        } else {
            setUser(null); // update App state
            navigate('/'); // redirect to home
        }
    };

    return (
        <div className="flex flex-row bg-white justify-between items-center sticky top-0">
            <div className="flex">
                <img
                    className="lg:w-[100px] md:w-[100px] w-[80px] m-2 cursor-pointer"
